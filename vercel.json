{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://statusmy-api.up.railway.app/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://statusmy-api.up.railway.app/socket.io/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
