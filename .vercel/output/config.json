{
  "version": 3,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "framework": {
    "version": "5.4.21"
  },
  "crons": [],
  "services": [
    {
      "name": "web",
      "type": "web",
      "workspace": ".",
      "routePrefix": "/",
      "routePrefixSource": "configured",
      "framework": "vite",
      "builder": {
        "src": "package.json",
        "use": "@vercel/static-build",
        "config": {
          "zeroConfig": true,
          "routePrefix": ".",
          "framework": "vite"
        }
      }
    }
  ]
}
